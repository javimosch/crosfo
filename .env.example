# Crosfo Environment Variables
# Copy this file to .env and customize for your environment

# Server Configuration
CROSFO_PORT=8081
CROSFO_HOST=127.0.0.1

# Database Configuration
CROSFO_DB_PATH=./ffaf.db

# Logging Configuration
CROSFO_LOG_LEVEL=INFO
CROSFO_LOG_FILE=/tmp/crosfo.log

# Daemon Configuration
CROSFO_PID_FILE=/tmp/crosfo.pid

# Behavior Configuration
CROSFO_NO_INTERACTIVE=1

# Output Configuration
NO_COLOR=1